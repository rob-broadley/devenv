#!/bin/sh
# Generate a static Lua table of installed tree-sitter parsers for Neovim.
#
# Scans /usr/lib64/tree-sitter/ for parser .so files, uses nm to discover
# the exported tree_sitter_* symbols for each, and writes the result to
# /etc/xdg/nvim/lua/treesitter_parsers.lua so that Neovim can load parsers
# at startup without any runtime discovery overhead.
#
# Run this script after installing or removing tree-sitter-* packages.

usage() {
    cat <<'EOF'
Usage: nvim-gen-treesitter-parsers [-h|--help]

Scan /usr/lib64/tree-sitter/ for installed parser .so files, resolve
tree_sitter_* symbols via nm, and write a static Lua registration table
to /etc/xdg/nvim/lua/treesitter_parsers.lua.

Run after installing, removing, or upgrading any tree-sitter-* package
(e.g. after zypper dup).

Options:
  -h, --help    Show this help text and exit

Exit status:
  0  Table written successfully (at least one parser registered)
  1  Fatal error: nm not found, scan directory missing, or no parsers found
EOF
}

set -eu

# Paths — adjust if the install prefix differs.
dir=/usr/lib64/tree-sitter
outfile=/etc/xdg/nvim/lua/treesitter_parsers.lua

# Force locale-independent output from nm and awk: character-class patterns
# like [a-z] and nm's symbol-line format are locale-dependent in some environments.
LC_ALL=C; export LC_ALL

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  *)
    if [ -n "${1:-}" ]; then
        printf 'Unknown option: %s\n' "${1:-}" >&2
        usage >&2
        exit 1
    fi
    ;;
esac

if [ ! -x /usr/bin/nm ]; then
    printf 'ERROR: /usr/bin/nm not found (install binutils)\n' >&2
    exit 1
fi

if [ ! -d "$dir" ]; then
    printf 'ERROR: %s not found — install tree-sitter-* packages first\n' "$dir" >&2
    exit 1
fi

outdir=$(dirname "$outfile")
mkdir -p "$outdir"
tmpfile=$(mktemp "$outdir/treesitter_parsers.XXXXXX")
nm_stderr=$(mktemp "/tmp/treesitter_parsers_nm.XXXXXX")
trap 'rm -f "$tmpfile" "$nm_stderr"' EXIT HUP INT TERM

cat > "$tmpfile" << 'LUAEOF'
-- Auto-generated by nvim-gen-treesitter-parsers. Do not edit.
return {
LUAEOF

count=0
for so in "$dir"/libtree-sitter-*.so; do
    [ -f "$so" ] || continue
    # Reject .so files that resolve via symlink to outside $dir (supply-chain guard).
    real_so=$(readlink -f "$so")
    case "$real_so" in
        "$dir"/*) ;;
        *) printf 'WARNING: %s resolves outside %s, skipping\n' "$so" "$dir" >&2; continue ;;
    esac
    : > "$nm_stderr"
    if ! nm_out=$(/usr/bin/nm -D --defined-only "$real_so" 2>"$nm_stderr"); then
        nm_err=$(cat "$nm_stderr")
        printf 'WARNING: nm failed on %s: %s, skipping\n' "$so" "$nm_err" >&2
        continue
    fi

    syms=$(printf '%s\n' "$nm_out" | awk '$3 ~ /^tree_sitter_[a-z][a-z0-9_]*$/ && $3 !~ /_external_scanner_/ { print $3 }')
    if [ -z "$syms" ]; then
        nm_err=$(cat "$nm_stderr")
        if [ -n "$nm_err" ]; then
            printf 'WARNING: no tree_sitter_* symbols found in %s: %s, skipping\n' "$so" "$nm_err" >&2
        else
            printf 'WARNING: no tree_sitter_* symbols found in %s, skipping\n' "$so" >&2
        fi
        continue
    fi

    IFS='
'
    for sym in $syms; do
        lang=${sym#tree_sitter_}
        case "$so$lang$sym" in
          *[!A-Za-z0-9_./:-]*)
            printf 'ERROR: unsafe characters in entry for %s (lang=%s sym=%s), skipping\n' "$so" "$lang" "$sym" >&2
            continue
            ;;
        esac
        printf '  {lang="%s", path="%s"},\n' "$lang" "$so" >> "$tmpfile"
        count=$((count + 1))
    done
    unset IFS
done

printf '}\n' >> "$tmpfile"

if [ "$count" -eq 0 ]; then
    printf 'ERROR: no parsers registered — check %s contains valid libtree-sitter-*.so files\n' "$dir" >&2
    exit 1
fi

# Set world-readable permissions then atomically promote into place with mv (rename(2)).
chmod 644 "$tmpfile"
mv "$tmpfile" "$outfile"

printf 'INFO: wrote %s with %d parser(s)\n' "$outfile" "$count" >&2
